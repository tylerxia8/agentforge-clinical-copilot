# Auth.js — server-side encryption key for the session JWT.
# Generate with `openssl rand -base64 32`. Required.
AUTH_SECRET=

# Public URL of THIS dashboard service. Auth.js needs it to compute
# OAuth redirect URIs and the absolute callback URL it registers
# with the OpenEMR client. Required in production; in dev,
# http://localhost:3000 is the default.
AUTH_URL=

# OpenEMR base URL — same one the agent service uses.
OPENEMR_BASE_URL=https://openemr-production-0996.up.railway.app

# OAuth2 issuer (= base URL + /oauth2/<site>). Auth.js fetches
# .well-known/openid-configuration off this to discover the
# authorize / token / userinfo endpoints.
OPENEMR_OAUTH_ISSUER=https://openemr-production-0996.up.railway.app/oauth2/default

# OAuth2 client credentials — register a NEW client for the
# dashboard with redirect URI:
#   ${AUTH_URL}/api/auth/callback/openemr
# The agent service's password-grant client doesn't apply here; we
# need one with token_endpoint_auth_method=client_secret_post AND a
# valid redirect_uri. See PATIENT_DASHBOARD_MIGRATION.md §6 for the
# registration curl one-liner.
OPENEMR_OAUTH_CLIENT_ID=
OPENEMR_OAUTH_CLIENT_SECRET=
