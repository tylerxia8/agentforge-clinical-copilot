# Local-repro test Dockerfile for the OpenEMR-embedded chat panel issue.
#
# Identical to the production Dockerfile EXCEPT it un-comments the
# module COPY line. Use docker-compose.test.yml to bring it up against
# a local MySQL so we can iterate without burning Railway build cycles.
#
# DO NOT POINT RAILWAY AT THIS FILE — the production railway.json
# specifies "dockerfilePath": "Dockerfile", which is the safe one.

FROM openemr/openemr:7.0.3

ENV OPENEMR__ENVIRONMENT=prod

COPY docker-entrypoint-wrapper.sh /docker-entrypoint-wrapper.sh
RUN chmod +x /docker-entrypoint-wrapper.sh
ENTRYPOINT ["/docker-entrypoint-wrapper.sh"]

# THE LINE WE'RE TESTING — bake the AgentForge co-pilot module into
# the OpenEMR image so it can be enabled via Module Manager.
COPY --chown=apache:apache interface/modules/custom_modules/oe-module-clinical-copilot \
     /var/www/localhost/htdocs/openemr/interface/modules/custom_modules/oe-module-clinical-copilot

# THE BOOT-STALL FIX —
# openemr.sh runs `find . -not -perm 600 -exec chmod 600 {} +` early in
# its entrypoint, walking ~57K files. With Docker's OverlayFS copy-on-
# write, each chmod copies the file from the lower (image) layer to the
# upper (container) layer — about 1 GB of writes total. On Railway's
# storage that pushed first-boot past the 15-min healthcheck window.
# Doing the chmod at IMAGE BUILD TIME instead writes one image layer
# in-place; openemr.sh's runtime find then sees nothing to change and
# finishes in seconds.
RUN cd /var/www/localhost/htdocs/openemr && \
    find . -not -perm 600 -exec chmod 600 {} +

EXPOSE 80
