# AgentForge — local development env vars.
# Copy to `.env` (already gitignored) and fill in real values.

# ─── REQUIRED for the agent-service ───────────────────────────────

# Anthropic API key (BAA-eligible direct contract).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret between the OpenEMR module and the agent service.
# Generate with:
#   python -c "import secrets;print(secrets.token_hex(32))"
# IMPORTANT: also paste this into OpenEMR after first boot:
#   Admin → Globals → Clinical Co-Pilot → copilot_agent_shared_secret
AGENT_SHARED_SECRET=

# ─── REQUIRED after first OpenEMR boot ────────────────────────────
# OpenEMR base URL the agent will talk to (no trailing slash).
# Local dev: http://openemr (the docker-compose service name)
# Production: https://openemr-production-0996.up.railway.app
OPENEMR_BASE_URL=

# 1. Register an OAuth2 client. Easiest is curl:
#    curl -X POST https://<openemr-host>/oauth2/default/registration \
#      -H 'Content-Type: application/json' \
#      -d '{
#        "application_type": "private",
#        "redirect_uris": ["https://<openemr-host>/oauth2/redirect"],
#        "client_name": "AgentForge Co-Pilot",
#        "token_endpoint_auth_method": "client_secret_post",
#        "scope": "openid offline_access api:fhir user/Patient.read user/Encounter.read user/Observation.read user/MedicationRequest.read user/Condition.read user/AllergyIntolerance.read user/Immunization.read"
#      }'
#    Save the client_id + client_secret from the response below.
# 2. In OpenEMR: Admin → System → API Clients → find your app → Enable.
#    Also enable: Authorization Code Grant + Password Grant.
OPENEMR_OAUTH_CLIENT_ID=
OPENEMR_OAUTH_CLIENT_SECRET=

# 3. Service-account user the agent runs as. Create a real OpenEMR user
#    (Admin → Users → New User) with a role that has patients/demo + med
#    ACL. We use Password Grant for v0/v1; production should swap to
#    client_credentials with private-key JWT — see ARCHITECTURE.md.
OPENEMR_SERVICE_USERNAME=
OPENEMR_SERVICE_PASSWORD=

# ─── REQUIRED for the W2 hybrid-RAG layer ─────────────────────────
# The orchestrator's evidence-retriever node uses Voyage voyage-3 for
# dense embeddings and Cohere Rerank 3 for cross-encoder rerank. Both
# degrade gracefully if unset (BM25-only retrieval, RRF fusion
# fallback) but the eval gate's `evidence` rubric assumes both are
# present, matching the locked baseline.
#  - https://www.voyageai.com/
#  - https://dashboard.cohere.com/api-keys
VOYAGE_API_KEY=
COHERE_API_KEY=

# Redis for the agent's per-patient context cache + tool-result
# bundle. Local dev: redis://localhost:6379/0 (the docker-compose
# `redis` service). Production: Railway's Redis plugin URL.
REDIS_URL=redis://localhost:6379/0

# ─── OPTIONAL (Sunday deliverable) ────────────────────────────────
# Self-hosted Langfuse for observability traces.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
